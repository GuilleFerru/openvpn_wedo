# Archivos de clientes (contienen credenciales)
clients/*.ovpn

# Mantener la carpeta clients
!clients/.gitkeep

# Variables de entorno (contienen contraseñas)
.env

# Sistema
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
Lib/
Scripts/
Include/
pyvenv.cfg
.env.local
.env.*.local
*.egg-info/
dist/
build/

# CCD (configuraciones de clientes - contienen IPs asignadas)
ccd/*
!ccd/.gitkeep

# Logs
*.log
logs/

# Docker (archivos locales)
docker-compose.override.yml

# Archivos temporales
*.tmp
*.bak
*.orig

# Certificados y claves (nunca subir)
*.key
*.crt
*.pem
*.p12
*.ovpn

# Archivos generados / temporales del proyecto
openvpn.conf.tmp
terminal.log
