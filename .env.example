# ============================================================
# Required — the application will NOT start without these
# ============================================================

# Web panel login password
ADMIN_PASSWORD=

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ============================================================
# Optional
# ============================================================

# LAN IP for dual-remote .ovpn files (local VM + cloud fallback).
# Leave empty (or remove) for single-remote deployments (GCE, etc.)
# LOCAL_SERVER_IP=192.168.1.100

# Docker volume name for OpenVPN data (default: openvpn_openvpn_data)
# VOLUME_NAME=openvpn_openvpn_data

# Domain for HTTPS via Traefik. Required for Let's Encrypt provisioning.
# DOMAIN=vpn.example.com

# Email for Let's Encrypt (required by ACME protocol).
# ACME_EMAIL=admin@example.com

# HTTP/HTTPS ports for Traefik.
# Local dev (Windows/Mac Docker Desktop): use high ports to avoid permission issues.
# Production (GCE Linux): set to 80 and 443.
# HTTP_PORT=8080
# HTTPS_PORT=8443
